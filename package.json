{
  "name": "@hunterzheng/harness",
  "version": "0.1.0",
  "description": "Personal development tool harness - unified CLI entrypoint",
  "type": "module",
  "bin": {
    "harness": "dist/bin/harness.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "cli",
    "harness",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "vitest": "^2.0.0",
    "eslint": "^9.6.0"
  }
}
